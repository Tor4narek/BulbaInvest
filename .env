# === App Global ===
JWT_SECRET=bulbainvest-super-secret-key-change-me-in-production
JWT_ISSUER=bulbainvest-domain
JWT_AUDIENCE=bulbainvest-clients
JWT_REALM=bulbainvest
JWT_TTL=2592000

# === Domain Service ===
DOMAIN_PORT=8040
DOMAIN_HOST_PORT=8040

# === Gateway ===
GATEWAY_PORT=8050
GATEWAY_HOST_PORT=8050
DOMAIN_SERVICE_URL=http://domain-service:8040

# === PostgreSQL ===
DB_NAME=domain
DB_USER=domain
DB_PASSWORD=changeme
DB_HOST_PORT=5482
DB_URL=jdbc:postgresql://postgres:5432/domain

# === Redis (General/Auth) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# === Broker Redis (Quotes) ===
BROKER_REDIS_HOST=broker-redis
BROKER_REDIS_PORT=6379
BROKER_REDIS_HOST_PORT=6380
BROKER_QUOTES_PREFIX=quotes:last:
BROKER_QUOTES_CHANNEL=market.quotes.updated
BROKER_STOCK_KEY_PREFIX=market:stocks:

# === Mail (MailHog) ===
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_HOST_PORT=1025
MAILHOG_UI_PORT=8025
MAIL_FROM=no-reply@bulbainvest.local
MAIL_USER=__NONE__
MAIL_PASSWORD=__NONE__

# === Market service (Go) ===
MARKET_SERVICE_PORT=8050
MARKET_SERVICE_HOST_PORT=8051
MARKET_TICK_INTERVAL=5s
MARKET_DRIVER_CONFIG=
# Domain service expects this URL for market data
STOCKS_MARKET_API_URL=http://market-service:8050

# === ClickHouse ===
CLICKHOUSE_HOST_PORT=8123
CLICKHOUSE_TCP_PORT=9000
