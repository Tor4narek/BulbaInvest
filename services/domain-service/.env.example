# Скопировать в .env и заполнить.

# === App ===
PORT=8040
APP_HOST_PORT=8040

# === PostgreSQL ===
DB_NAME=domain
DB_USER=domain
DB_PASSWORD=changeme
DB_HOST_PORT=5482
DB_URL=jdbc:postgresql://postgres:5432/domain

# === Redis (auth codes) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# === Broker Redis (quotes) ===
BROKER_REDIS_HOST=broker-redis
BROKER_REDIS_PORT=6379
BROKER_REDIS_HOST_PORT=6380
BROKER_QUOTES_PREFIX=quotes:last:

# === Mail (MailHog) ===
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_HOST_PORT=1025
MAILHOG_UI_PORT=8025
MAIL_FROM=no-reply@bulbainvest.local
MAIL_USER=__NONE__
MAIL_PASSWORD=__NONE__

# === Stocks Market API (Go) ===
STOCKS_MARKET_API_URL=http://stocks-market:8080

# === Market service (Go + C driver) ===
MARKET_SERVICE_HOST_PORT=8050
MARKET_TICK_INTERVAL=10s
MARKET_DRIVER_CONFIG=

# === JWT ===
JWT_SECRET=please-generate-a-long-random-string
JWT_ISSUER=bulbainvest-domain
JWT_AUDIENCE=bulbainvest-clients
JWT_REALM=bulbainvest
JWT_TTL=2592000
